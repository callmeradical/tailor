#!/bin/sh
# tailor — thin wrapper around ansible-playbook for personal machine config
#
# Usage: tailor <command> [options]
#
# Commands:
#   apply [--check] [--role <name>] [--verbose]
#       Apply configuration to the local machine.
#       --check    Dry-run: show what would change without modifying anything
#                  (runs ansible-playbook --check, not syntax-check)
#       --role     Apply only a specific role, identified by tag name
#                  (maps to ansible-playbook --tags <name>)
#       --verbose  Enable verbose Ansible output (-v)
#
#   validate
#       Syntax-check the playbook without applying any changes
#       (runs ansible-playbook --syntax-check)
#
#   check
#       Alias for: apply --check
#
#   adopt brew <package>
#       Add an already-installed Homebrew package to the declared config.
#
#   adopt file <path>
#       Register an existing config file into the dotfiles role.
#
#   usage, --usage
#       Print agent-oriented usage instructions (machine-readable briefing)
#
#   help, --help, -h
#       Show this help text
#
# Environment:
#   TAILOR_CONFIG_DIR  Config repo location (default: ~/.config/tailor)
#   EDITOR             Editor opened after adopt writes (default: vi)
#
# Decisions:
#   --role maps to ansible-playbook --tags <name> so that a single site.yml
#   can selectively run a role without maintaining per-role playbooks. Ansible
#   tags offer the same granularity with less overhead. Tag each role in
#   site.yml with its role name to take advantage of this.
#
#   apply --check runs ansible-playbook --check (real dry-run that connects to
#   the control path and evaluates conditionals). validate runs --syntax-check
#   (parse-only, no task evaluation). These serve different purposes and should
#   not be confused.

set -euo pipefail

# Detect whether TAILOR_CONFIG_DIR was explicitly provided by the caller.
# If it was, honour it unconditionally (enables testing with fixtures and lets
# users override the default without the dev-worktree heuristic interfering).
_tailor_config_explicit="${TAILOR_CONFIG_DIR+set}"
TAILOR_CONFIG_DIR="${TAILOR_CONFIG_DIR:-$HOME/.config/tailor}"

# Locate playbook directory.
#   1. If TAILOR_CONFIG_DIR was explicitly set, use it.
#   2. Otherwise, if running from a development worktree (site.yml is in the
#      repo root next to bin/), use the repo root — no TAILOR_CONFIG_DIR setup
#      required during development.
#   3. Fall back to TAILOR_CONFIG_DIR (production install).
_script_dir="$(cd "$(dirname "$0")/.." && pwd)"
_lib_dir="$_script_dir/lib"
if [ "$_tailor_config_explicit" = "set" ]; then
  PLAYBOOK_DIR="$TAILOR_CONFIG_DIR"
elif [ -f "$_script_dir/site.yml" ]; then
  PLAYBOOK_DIR="$_script_dir"
elif [ -f "$TAILOR_CONFIG_DIR/site.yml" ]; then
  PLAYBOOK_DIR="$TAILOR_CONFIG_DIR"
else
  echo "tailor: no site.yml found in $_script_dir or $TAILOR_CONFIG_DIR" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
Usage: tailor <command> [options]

Commands:
  apply [--check] [--role <name>] [--verbose]
      Apply configuration to the local machine.
      --check    Dry-run — show what would change without modifying anything
      --role     Apply only one role by tag name (e.g. --role packages)
      --verbose  Verbose Ansible output

  validate
      Syntax-check the playbook (no changes, no task evaluation)

  check
      Alias for: apply --check

  adopt brew <package>
      Add an already-installed Homebrew package to the declared config
  adopt file <path>
      Register an existing config file into the dotfiles role

  usage, --usage
      Print agent-oriented usage instructions

  help, --help, -h
      Show this message

Environment:
  TAILOR_CONFIG_DIR   Config repo location (default: ~/.config/tailor)
  EDITOR              Editor opened after adopt writes (default: vi)
EOF
}

# ---------------------------------------------------------------------------
cmd_apply() {
  check_flag=0
  verbose_flag=0
  role_filter=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --check)        check_flag=1; shift ;;
      --verbose|-v)   verbose_flag=1; shift ;;
      --role)
        if [ $# -lt 2 ] || [ -z "$2" ]; then
          echo "tailor apply: --role requires an argument" >&2
          exit 1
        fi
        role_filter="$2"; shift 2 ;;
      *)
        echo "tailor apply: unknown option '$1'" >&2
        usage >&2
        exit 1 ;;
    esac
  done

  set -- ansible-playbook -i localhost, -c local "$PLAYBOOK_DIR/site.yml"

  if [ -n "$role_filter" ]; then
    set -- "$@" --tags "$role_filter"
  fi

  if [ "$check_flag" -eq 1 ]; then
    echo "tailor: dry-run (--check) on $PLAYBOOK_DIR/site.yml" >&2
    set -- "$@" --check
  else
    echo "tailor: applying $PLAYBOOK_DIR/site.yml" >&2
  fi

  if [ "$verbose_flag" -eq 1 ]; then
    set -- "$@" -v
  fi

  "$@"
}

# ---------------------------------------------------------------------------
cmd_adopt() {
  _subcommand="${1:-}"
  shift || true
  case "$_subcommand" in
    brew|file)
      sh "$_lib_dir/adopt.sh" "$_subcommand" "${1:-}"
      ;;
    "")
      echo "tailor adopt: usage: tailor adopt <brew|file> <argument>" >&2; exit 1 ;;
    *)
      echo "tailor adopt: unknown subcommand '$_subcommand' (expected brew or file)" >&2; exit 1 ;;
  esac
}

# ---------------------------------------------------------------------------
cmd_usage() {
  config_dir="${TAILOR_CONFIG_DIR:-$HOME/.config/tailor}"
  cat <<EOF
TAILOR — Personal Machine Configuration Manager
================================================
Ansible-native. Bootstrap from zero with one command. Declare your machine
state in a git repo; tailor converges your machine to match it.

AGENT QUICK-START
-----------------
1. Read the config:         cat $config_dir/group_vars/all.yml
2. Dry-run (safe, no changes):  tailor apply --check
3. Apply everything:        tailor apply
4. Apply one role:          tailor apply --role packages
5. Check syntax only:       tailor validate
6. Capture a brew package:  tailor adopt brew <package>
7. Capture a config file:   tailor adopt file <path>

CONFIG LOCATION
---------------
  $config_dir/
    group_vars/all.yml   — primary config (packages, dotfiles url, prefs)
    site.yml             — main Ansible playbook (do not edit unless extending)
    roles/
      packages/          — Homebrew formulae + casks
      dotfiles/          — dotfiles repo clone + installer
      macos-prefs/       — osx_defaults (dock, keyboard, trackpad, screenshots)
      vscode/            — VS Code extensions
      hooks/             — pre/post apply shell scripts

KEY VARIABLES (group_vars/all.yml)
-----------------------------------
  homebrew_packages: [...]     — list of brew formulae to install
  homebrew_casks: [...]        — list of brew cask apps to install
  dotfiles_repo_url: "..."     — git URL of dotfiles repo (empty = skip)
  vscode_extensions: [...]     — VS Code extension IDs (empty = skip)
  macos_dock_autohide: true    — autohide dock
  macos_dock_tilesize: 48      — dock icon size in pixels
  macos_key_repeat: 2          — key repeat rate (1=fastest)
  macos_initial_key_repeat: 15 — initial key repeat delay
  macos_trackpad_tap_to_click: true
  macos_screenshot_location: ~/Desktop

ROLES (use with --role flag)
-----------------------------
  packages   — install Homebrew formulae and casks
  dotfiles   — clone dotfiles repo and run its installer
  macos-prefs / prefs — apply macOS system preferences
  vscode     — install VS Code extensions
  hooks      — run pre/post shell scripts (no-op if scripts absent)

ADOPT WORKFLOW (capture ad-hoc changes)
----------------------------------------
  # You installed something manually — declare it:
  brew install ripgrep
  tailor adopt brew ripgrep

  # You edited a config file — version-control it:
  tailor adopt file ~/.gitconfig

  Both commands are idempotent and open the modified file in \$EDITOR.

ENVIRONMENT
-----------
  TAILOR_CONFIG_DIR   Override config repo location (default: ~/.config/tailor)
  EDITOR              Editor for adopt command (default: vi)

SAFE OPERATIONS (no system changes)
-------------------------------------
  tailor apply --check     — always safe, shows diff only
  tailor validate          — syntax check, never touches system
  tailor --usage           — this output

DOCS: https://callmeradical.github.io/tailor
EOF
}

# ---------------------------------------------------------------------------
cmd_validate() {
  echo "tailor: validating (syntax-check) $PLAYBOOK_DIR/site.yml" >&2
  ansible-playbook --syntax-check -i localhost, -c local "$PLAYBOOK_DIR/site.yml"
}

# ---------------------------------------------------------------------------
cmd="${1:-}"
[ $# -gt 0 ] && shift || true

case "$cmd" in
  apply)
    cmd_apply "$@" ;;
  check)
    cmd_apply --check "$@" ;;
  validate)
    cmd_validate ;;
  adopt)
    cmd_adopt "$@" ;;
  usage|--usage)
    cmd_usage ;;
  help|--help|-h)
    usage ;;
  "")
    usage
    exit 1 ;;
  *)
    echo "tailor: unknown command '$cmd'" >&2
    usage >&2
    exit 1 ;;
esac
